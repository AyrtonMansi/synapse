# Synapse Web UI Environment Variables
# Copy to .env.local for local development
# Set in Vercel Dashboard for production

# ===========================================
# Required
# ===========================================

# Gateway API URL (HTTP REST API)
# Local: http://localhost:3001
# Staging: https://api.staging.synapse.sh
# Production: https://api.synapse.sh
VITE_API_URL=http://localhost:3001

# WebSocket Router URL
# Local: ws://localhost:3002/ws
# Staging: wss://ws.staging.synapse.sh/ws
# Production: wss://ws.synapse.sh/ws
VITE_WS_URL=ws://localhost:3002/ws

# ===========================================
# Demo Mode (when backend not deployed)
# ===========================================

# Enable demo mode - uses mock API responses
VITE_DEMO_MODE=true

# ===========================================
# Optional
# ===========================================

# Blockchain chain ID
# 31337 = Hardhat local
# 1 = Ethereum mainnet
# 11155111 = Sepolia testnet
VITE_CHAIN_ID=31337

# Enable WalletConnect (if using web3 features)
VITE_ENABLE_WALLETCONNECT=false

# WalletConnect Project ID (required if enabled)
# Get from: https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=

# Network name for display
VITE_NETWORK_NAME=Local

# Feature flags
VITE_ENABLE_MINING_DASHBOARD=true
VITE_ENABLE_BILLING=false
