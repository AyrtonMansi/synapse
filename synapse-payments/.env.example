# Synapse Payments Service - Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/synapse_payments?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Blockchain Configuration
TREASURY_PRIVATE_KEY=0x...
TREASURY_ADDRESS=0x...
HSK_TOKEN_ADDRESS=0x...
CHAIN_ID=11155111

# RPC URLs
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-rpc.com
BASE_RPC_URL=https://mainnet.base.org
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# KYC Configuration
KYC_PROVIDER=stripe  # Options: sumsub, onfido, stripe
KYC_API_KEY=
KYC_SECRET_KEY=
KYC_WEBHOOK_SECRET=

# Company Information (for receipts)
COMPANY_NAME="Synapse Network Inc."
COMPANY_ADDRESS="123 Blockchain St, San Francisco, CA 94102"
COMPANY_TAX_ID="12-3456789"

# Admin Configuration
ADMIN_EMAILS=admin@synapse.network,founder@synapse.network

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:3000

# JWT Secret (for auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AWS/S3 (for receipts storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
RECEIPT_S3_BUCKET=synapse-receipts

# API Gateway Integration
API_GATEWAY_URL=http://localhost:3000
API_GATEWAY_KEY=