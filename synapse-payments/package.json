{
  "name": "@synapse/payments",
  "version": "1.0.0",
  "description": "Hybrid fiat/crypto payment system for Synapse Network",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "stripe:listen": "stripe listen --forward-to localhost:3001/webhooks/stripe",
    "deploy:contracts": "hardhat run scripts/deploy.ts --network"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@stripe/stripe-js": "^2.2.0",
    "stripe": "^14.9.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "ethers": "^6.9.0",
    "siwe": "^2.1.4",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "rate-limiter-flexible": "^4.0.1",
    "node-cron": "^3.0.3",
    "pdf-lib": "^1.17.1",
    "fast-csv": "^5.0.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/node": "^20.10.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.2",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "synapse",
    "payments",
    "stripe",
    "crypto",
    "hsk",
    "hybrid"
  ],
  "license": "MIT"
}