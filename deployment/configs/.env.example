# Synapse Network - Environment Variables

# ========================================
# Network Configuration
# ========================================
NETWORK=mainnet
CHAIN_ID=1

# ========================================
# RPC Endpoints
# ========================================
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ========================================
# Private Keys (KEEP SECURE!)
# ========================================
# Mainnet deployer key (use hardware wallet in production)
MAINNET_PRIVATE_KEY=0x...
# Testnet deployer key
SEPOLIA_PRIVATE_KEY=0x...

# ========================================
# Multisig Configuration
# ========================================
MULTISIG_ADDRESS=0x...
MULTISIG_THRESHOLD=3
MULTISIG_SIGNERS=5

# ========================================
# Contract Addresses (Mainnet)
# ========================================
# These will be populated after deployment
HSK_TOKEN_ADDRESS=0x...
TREASURY_DAO_ADDRESS=0x...
PRICE_ORACLE_ADDRESS=0x...
DISPUTE_RESOLVER_ADDRESS=0x...
JOB_REGISTRY_ADDRESS=0x...
STREAMING_PAYMENTS_ADDRESS=0x...

# ========================================
# API Keys
# ========================================
ETHERSCAN_API_KEY=...
INFURA_KEY=...
ALCHEMY_KEY=...
GRAPH_ACCESS_TOKEN=...

# ========================================
# Database Configuration
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=synapse
DB_PASSWORD=secure_password_here
DATABASE_URL=postgresql://synapse:secure_password_here@localhost:5432/synapse

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=secure_redis_password

# ========================================
# Monitoring
# ========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secure_grafana_password
PROMETHEUS_RETENTION=30d

# ========================================
# IPFS Configuration
# ========================================
IPFS_SWARM_KEY=/key/swarm.key
IPFS_CLUSTER_SECRET=secret_here

# ========================================
# Security
# ========================================
JWT_SECRET=random_secure_string_min_32_chars
API_RATE_LIMIT=1000
API_RATE_WINDOW=60

# ========================================
# External Services
# ========================================
CHAINLINK_ETH_USD_FEED=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
UNISWAP_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564

# ========================================
# Notifications
# ========================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
PAGERDUTY_KEY=...

# ========================================
# Feature Flags
# ========================================
ENABLE_STREAMING_PAYMENTS=true
ENABLE_DISPUTE_RESOLUTION=true
ENABLE_DAO_GOVERNANCE=true
DEBUG=false
