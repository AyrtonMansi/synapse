# Default configuration for Synapse Node
# Copy this file to .env and customize for your setup

# ============================================================================
# Node Identity
# ============================================================================
SYNAPSE_NODE_NAME=my-synapse-node
# SYNAPSE_NODE_ID=auto-generated-if-not-set

# ============================================================================
# Network Configuration
# ============================================================================
SYNAPSE_NETWORK_RPC_URL=wss://mesh.synapse.network/v1/ws
SYNAPSE_API_HOST=0.0.0.0
SYNAPSE_API_PORT=8080

# ============================================================================
# GPU Configuration
# ============================================================================
# Use all GPUs (set to specific indices like "0,1" for multi-GPU)
NVIDIA_VISIBLE_DEVICES=all
SYNAPSE_GPU_MEMORY_FRACTION=0.9

# ============================================================================
# Model Configuration
# ============================================================================
SYNAPSE_MODEL_CACHE_DIR=/app/models
# Comma-separated list of default models to preload
SYNAPSE_DEFAULT_MODELS=meta-llama/Llama-2-7b-chat-hf,mistralai/Mistral-7B-Instruct-v0.2
SYNAPSE_MAX_MODEL_MEMORY_GB=14

# ============================================================================
# Inference Settings
# ============================================================================
SYNAPSE_MAX_CONCURRENT_REQUESTS=32
SYNAPSE_REQUEST_TIMEOUT_SECONDS=120
SYNAPSE_MAX_TOKENS_DEFAULT=2048

# ============================================================================
# Wallet Configuration (REQUIRED)
# ============================================================================
# Set your Ethereum wallet private key (with 0x prefix)
# SYNAPSE_WALLET_PRIVATE_KEY=0x...
# SYNAPSE_WALLET_ADDRESS=0x...

# ============================================================================
# Proof Generation
# ============================================================================
SYNAPSE_PROOF_ENABLED=true
SYNAPSE_PROOF_CIRCUIT_PATH=/app/circuits

# ============================================================================
# Monitoring
# ============================================================================
SYNAPSE_PROMETHEUS_PORT=9090
SYNAPSE_LOG_LEVEL=INFO

# ============================================================================
# HuggingFace
# ============================================================================
# Set your HuggingFace token for accessing gated models
# HUGGING_FACE_HUB_TOKEN=hf_...
