{
  "name": "synapse-api-gateway",
  "version": "1.0.0",
  "description": "Synapse API Gateway - Wallet-based authentication and routing with enterprise security",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:integration": "mocha ../tests/integration/**/*.test.js --timeout 30000",
    "test:security": "npm audit && snyk test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "security:check": "node scripts/security-check.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "express-validator": "^7.0.1",
    "siwe": "^2.1.4",
    "ethers": "^6.9.1",
    "jsonwebtoken": "^9.0.2",
    "ioredis": "^5.3.2",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "prom-client": "^15.1.0",
    "ipfs-http-client": "^60.0.1",
    "libp2p": "^0.46.21",
    "@libp2p/tcp": "^8.0.13",
    "@libp2p/mplex": "^9.0.12",
    "@libp2p/noise": "^13.0.5",
    "multiformats": "^12.1.3",
