  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "snyk": "^1.1266.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "snyk": true
}
