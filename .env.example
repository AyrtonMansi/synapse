# Synapse Deployment Configuration
# Copy to .env and fill in your values

# ===========================================
# Deployment Mode
# ===========================================
DEPLOYMENT_ENV=staging  # staging | production

# ===========================================
# Domain Configuration
# ===========================================
DOMAIN=synapse.sh
API_SUBDOMAIN=api
WS_SUBDOMAIN=ws
APP_SUBDOMAIN=app

# Full URLs (constructed if not provided)
# API_URL=https://api.synapse.sh
# WS_URL=wss://ws.synapse.sh
# APP_URL=https://app.synapse.sh
# LANDING_URL=https://synapse.sh

# ===========================================
# CORS Origins (comma-separated)
# ===========================================
CORS_ORIGINS=https://app.synapse.sh,https://synapse.sh,https://*.vercel.app

# ===========================================
# Gateway API
# ===========================================
GATEWAY_PORT=3001
GATEWAY_DATABASE_URL=/app/data/gateway.db

# ===========================================
# Router (WebSocket)
# ===========================================
ROUTER_PORT=3002
ROUTER_COORDINATOR_URL=http://coordinator:3003

# ===========================================
# Coordinator
# ===========================================
COORDINATOR_PORT=3003

# ===========================================
# Settlement Daemon
# ===========================================
SETTLEMENT_INTERVAL_MS=60000
SETTLEMENT_BATCH_SIZE=100

# ===========================================
# Node Agent (for demo/testing only)
# ===========================================
NODE_WALLET=0xDemoNodeWallet
NODE_MODEL_PROFILE=echo-stub
NODE_ID=demo-node-001

# ===========================================
# SSL/TLS
# ===========================================
# Path to SSL certificates on host (for nginx)
SSL_CERT_PATH=/app/infra/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/app/infra/nginx/ssl/privkey.pem

# Let's Encrypt email (for certbot)
LETSENCRYPT_EMAIL=admin@synapse.sh

# ===========================================
# Monitoring (optional)
# ===========================================
LOG_LEVEL=info
METRICS_ENABLED=false
