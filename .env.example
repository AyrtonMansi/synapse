# Synapse Network - Environment Configuration

# =============================================================================
# Gateway API Configuration
# =============================================================================
PORT=3001
DATABASE_URL=/app/data/gateway.db
ROUTER_URL=http://localhost:3002

# Security settings
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
STATS_CACHE_TTL=5000

# Router authentication (optional - enables secure gateway->router communication)
ROUTER_SECRET=your-secret-key-here-change-in-production

# =============================================================================
# Router Configuration
# =============================================================================
ROUTER_PORT=3002
ENABLE_DISPATCH_AUTH=false
# ROUTER_SECRET must match gateway's ROUTER_SECRET when ENABLE_DISPATCH_AUTH=true

# =============================================================================
# Node Agent Configuration
# =============================================================================
# Standard node
NODE_WALLET=0xYourNodeWalletAddressHere
MODEL_PROFILE=echo-stub
NODE_ID=your-node-id

# vLLM GPU node (use with --profile gpu)
VLLM_NODE_WALLET=0xYourVLLMNodeWalletAddressHere
VLLM_MODEL_PROFILE=vllm
VLLM_NODE_ID=your-vllm-node-id
VLLM_URL=http://localhost:8000/v1

# =============================================================================
# Web UI Configuration
# =============================================================================
VITE_API_URL=http://localhost:3001

# =============================================================================
# Blockchain (Optional - for on-chain features)
# =============================================================================
CHAIN_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=11155111
CONTRACT_HSK_TOKEN=0x...
CONTRACT_JOB_REGISTRY=0x...
CONTRACT_TREASURY_DAO=0x...

# =============================================================================
# IPFS (Optional)
# =============================================================================
IPFS_NODE=/ip4/127.0.0.1/tcp/5001
IPFS_GATEWAY=https://ipfs.io/ipfs/

# =============================================================================
# P2P Mesh (Optional)
# =============================================================================
MESH_BOOTSTRAP=/dns4/bootstrap.synapse.network/tcp/443/wss/p2p/12D3KooW...
MESH_PORT=8080

# =============================================================================
# GPU Settings (Optional)
# =============================================================================
GPU_DEVICE=cuda:0
MODEL_CACHE=/app/models

# =============================================================================
# IMPORTANT SECURITY NOTES
# =============================================================================
# 1. NEVER commit this file with real secrets to git
# 2. Generate strong random values for ROUTER_SECRET in production
# 3. Use unique NODE_WALLET addresses for each node
# 4. Private keys are NOT stored here - use wallet connection only
