{
  "name": "synapse-testing",
  "version": "1.0.0",
  "description": "Comprehensive Testing & QA Suite for Synapse",
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:performance",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:security": "node security/run-security-tests.js",
    "test:performance": "node performance/run-benchmarks.js",
    "test:e2e": "playwright test",
    "test:load": "k6 run performance/load-tests/",
    "fuzz": "node security/fuzzing/contract-fuzzer.js",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write .",
    "report:merge": "node utils/merge-reports.js",
    "ci": "npm run lint && npm run test && npm run coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ethers": "^6.9.0",
    "ws": "^8.14.0",
    "libp2p": "^0.46.0",
    "@libp2p/tcp": "^9.0.0",
    "@libp2p/websockets": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "k6": "^0.47.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
