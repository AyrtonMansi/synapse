# Synapse Environment Configuration

# ==========================================
# Core Settings
# ==========================================
NODE_ENV=development
DOMAIN=localhost

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ==========================================
# Blockchain Configuration
# ==========================================
RPC_URL=http://localhost:8545
MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deployed Contract Addresses (update after deployment)
JOB_CONTRACT=0x0000000000000000000000000000000000000000
RATE_LIMIT_CONTRACT=0x0000000000000000000000000000000000000000
REPUTATION_CONTRACT=0x0000000000000000000000000000000000000000

# Deployer Key (local dev only - do not use in production!)
DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ==========================================
# IPFS Configuration
# ==========================================
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# Optional: External Pinning Service
PINNING_SERVICE=pinata
PINNING_KEY=your-pinata-api-key
PINNING_SECRET=your-pinata-secret

# ==========================================
# P2P Mesh Configuration
# ==========================================
NETWORK_ID=local-dev-v1
BOOTSTRAP_PEERS=
CAPABILITIES=compute,storage,ai
MAX_CONCURRENT_JOBS=5

# ==========================================
# The Graph Configuration
# ==========================================
GRAPH_NODE_URL=http://localhost:8020
GRAPH_IPFS_URL=http://localhost:5001

# ==========================================
# Monitoring (Optional)
# ==========================================
GRafana_PASSWORD=admin

# ==========================================
# API Gateway
# ==========================================
API_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# Job Router
# ==========================================
ROUTER_PORT=4000
P2P_PORT_RANGE=10000-10100

# ==========================================
# IPFS Service
# ==========================================
IPFS_SERVICE_PORT=5002