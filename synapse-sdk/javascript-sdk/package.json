{
  "name": "@synapse-ai/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for Synapse AI API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docs:build": "typedoc src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "synapse",
    "ai",
    "llm",
    "openai",
    "api",
    "sdk",
    "typescript",
    "streaming",
    "embeddings"
  ],
  "author": "Synapse AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/synapse-ai/sdk-javascript.git"
  },
  "bugs": {
    "url": "https://github.com/synapse-ai/sdk-javascript/issues"
  },
  "homepage": "https://docs.synapse.ai/sdk/javascript",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}